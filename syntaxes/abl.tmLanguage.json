{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "OpenEdge ABL",
  "scopeName": "source.abl",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#preprocessor"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#labels"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#types"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.abl",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "include": "#comments"
            }
          ]
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.abl",
          "match": "^\\s*&\\w+\\b.*$"
        },
        {
          "name": "variable.other.preprocessor.abl",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            {
              "include": "#strings"
            }
          ]
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "entity.name.label.abl",
          "match": "(?i)^\\s*(?!(?:do|repeat|for|case|if|else|procedure|function|method|constructor|destructor|class|interface)\\b)[a-z_][a-z0-9_-]*\\s*:(?=\\s*(?:(?:do|repeat|for|case)\\b|.*\\bthen\\s+do\\b|else\\s+do\\b))"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.abl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.abl",
              "match": "~(?:\\r?\\n|.)"
            }
          ]
        },
        {
          "name": "string.quoted.single.abl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.abl",
              "match": "~(?:\\r?\\n|.)"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.abl",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.abl",
          "match": "(?i)(?<![A-Za-z0-9_-])(character|char|integer|int|inte|int64|decimal|blob|dec|deci|logi|logical|log|date|datetime|datetime-tz|handle|longchar|memptr|raw|recid|rowid|widget-handle|com-handle|class)(?![A-Za-z0-9_-])"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.abl",
          "match": "(?i)(?<![A-Za-z0-9_-])(if|then|else|do|end|not|case|when|otherwise|repeat|for|each|while|BREAK|BY|leave|next|last|prev|first|return|run|of|as|at|on|in|procedure|function|transaction|method|catch|finally|throw|undo|retry|stop|quit)(?![A-Za-z0-9_-])"
        },
        {
          "name": "storage.modifier.abl",
          "match": "(?i)(?<![A-Za-z0-9_-])(dynamic-current-value|soap-header-entryref|put-unsigned-short|put-unsigned-long|set-pointer-value|client-principal|current-language|dynamic-property|stored-procedure|transaction-mode|buffer-compare|current-window|exclusive-lock|max-frame-down|sax-attributes|selection-list|set-byte-order|this-procedure|current-value|get-key-value|global-define|os-create-dir|printer-setup|put-key-value|routine-level|scoped-define|server-socket|system-dialog|value-changed|fix-codepage|input-output|load-picture|query-tuning|raw-transfer|window-close|active-form|before-hide|block-level|buffer-copy|constructor|data-source|description|dynamic-new|frame-value|index-field|next-prompt|side-labels|soap-header|system-help|this-object|unformatted|unsubscribe|widget-pool|accumulate|assignment|automation|descending|destructor|dictionary|disconnect|frame-down|frame-line|os-command|prompt-for|put-double|put-string|reposition|sax-reader|sax-writer|share-lock|show-stats|stop-after|temp-table|work-table|x-document|aggregate|alert-box|ascending|automatic|available|combo-box|dump-name|interface|max-width|no-labels|os-append|os-delete|os-rename|parameter|preselect|procedure|protected|put-bytes|put-float|put-int64|put-short|radio-set|rectangle|subscribe|substring|terminate|underline|use-index|x-noderef|abstract|centered|copy-lob|database|decimals|external|function|get-file|initiate|messages|no-apply|no-error|no-label|no-pause|override|position|property|put-bits|put-byte|put-long|question|set-size|sub-menu|terminal|triggers|undefine|use-text|validate|variable|wait-for|workfile|buttons|columns|compile|connect|dataset|default|disable|display|editing|execute|finally|get-dir|initial|message|no-lock|no-undo|no-wait|os-copy|overlay|primary|private|process|promsgs|propath|publish|readkey|release|request|through|trigger|view-as|advise|append|assign|browse|buffer|button|center|choose|column|create|cursor|define|delete|editor|enable|endkey|events|export|extent|format|global|header|import|insert|length|method|no-box|normal|object|output|public|record|repeat|return|screen|scroll|server|shared|silent|slider|socket|static|status|stream|unique|unload|update|widget|yes-no|alias|apply|avail|cache|catch|class|clear|close|colon|color|empty|entry|error|event|field|frame|image|index|input|label|leave|order|pause|query|super|throw|title|using|where|width|area|bell|call|case|desc|down|else|enum|find|font|form|from|help|hide|info|init|like|load|menu|next|open|page|quit|save|seek|send|size|skip|stop|then|undo|unix|view|with|add|all|asc|col|dde|def|dos|end|for|get|new|put|raw|row|run|set|use|var|at|do|if|ok|on|to|up)(?![A-Za-z0-9_-])"
        },
        {
          "name": "constant.language.abl",
          "match": "(?i)(?<![A-Za-z0-9_-])(true|false|yes|no|unknown|today|now)(?![A-Za-z0-9_-])|\\?"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.abl",
          "match": "(?i)(?<![A-Za-z0-9_-])(get-effective-tenant-name|get-effective-tenant-id|generate-password-hash|dynamic-current-value|data-source-modified|process-architecture|set-effective-tenant|buffer-partition-id|generate-random-key|buffer-tenant-name|current-result-row|dynamic-next-value|get-unsigned-short|is-column-codepage|is-db-multi-tenant|buffer-group-name|generate-pbe-salt|get-pointer-value|get-unsigned-long|is-codepage-fixed|tenant-name-to-id|buffer-tenant-id|codepage-convert|current-language|dynamic-function|dynamic-property|generate-pbe-key|list-query-attrs|buffer-group-id|current-changed|ssl-server-name|db-remote-host|dbrestrictions|dynamic-invoke|get-byte-order|get-collations|list-set-attrs|message-digest|audit-enabled|base64-decode|base64-encode|current-value|generate-salt|generate-uuid|get-codepages|get-collation|get-db-client|is-attr-space|message-lines|query-off-end|record-length|set-db-client|widget-handle|add-interval|dynamic-cast|dynamic-enum|get-codepage|is-lead-byte|line-counter|list-widgets|program-name|return-value|screen-lines|valid-handle|valid-object|dataservers|datetime-tz|dbcollation|frame-field|frame-index|frame-value|keyfunction|keyword-all|list-events|num-aliases|num-entries|num-results|page-number|proc-handle|proc-status|sha1-digest|tenant-name|transaction|valid-event|dbcodepage|frame-down|frame-file|frame-line|frame-name|get-double|get-string|go-pending|hex-decode|hex-encode|md5-digest|next-value|proversion|right-trim|substitute|ambiguous|available|can-query|connected|dbversion|frame-col|frame-row|get-bytes|get-class|get-float|get-int64|get-short|hash-code|left-trim|normalize|os-drives|os-getenv|page-size|rgb-value|row-state|setuserid|substring|tenant-id|absolute|can-find|count-of|datetime|dbtaskid|first-of|frame-db|gateways|get-bits|get-byte|get-long|get-size|interval|iso-date|keylabel|os-error|progress|rejected|terminal|timezone|to-rowid|truncate|can-set|compare|dbparam|decimal|decrypt|encrypt|entered|integer|kblabel|keycode|keyword|last-of|lastkey|ldbname|library|logical|maximum|minimum|num-dbs|pdbname|promsgs|propath|r-index|replace|sdbname|type-of|weekday|can-do|dbname|dbtype|encode|extent|handle|length|locked|lookup|member|quoter|random|search|string|userid|accum|alias|entry|error|etime|first|index|input|int64|disp|month|mtime|opsys|recid|retry|round|rowid|super|today|unbox|caps|cast|date|fill|guid|last|seek|sqrt|time|trim|year|asc|box|chr|day|exp|log|now|raw|lc)(?![A-Za-z0-9_-])(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.abl",
          "match": "(?i)(?<![A-Za-z0-9_-])(and|or|not|eq|ne|lt|le|gt|ge|begins|contains|matches|modulo)(?![A-Za-z0-9_-])|<>|<=|>=|=|<|>|\\+|(?<![A-Za-z0-9_])-(?![A-Za-z0-9_])|\\*|/|@"
        }
      ]
    }
  }
}
